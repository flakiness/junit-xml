{
  "name": "@flakiness/junit-xml",
  "version": "1.2.0",
  "packageManager": "pnpm@11.5.0",
  "private": false,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/flakiness/junit-xml.git"
  },
  "description": "Convert JUnit XML test reports into Flakiness Reports",
  "bin": {
    "flakiness-junit-xml": "lib/cli.js"
  },
  "scripts": {
    "build": "kubik build.mts",
    "watch": "kubik build.mts -w",
    "test": "bun test tests/ --reporter=junit --reporter-outfile=junit.xml"
  },
  "keywords": [
    "junit",
    "junit-xml",
    "surefire",
    "testng",
    "flakiness",
    "testing",
    "reporter"
  ],
  "author": "Degu Labs, Inc",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": "^20.17.0 || >=22.9.0"
  },
  "devDependencies": {
    "@flakiness/flakiness-report": "^0.34.0",
    "@flakiness/sdk": "^3.2.0",
    "@rgrove/parse-xml": "^4.2.0",
    "@types/bun": "^1.3.14",
    "@types/node": "^25.0.3",
    "commander": "^14.0.3",
    "esbuild": "^0.27.2",
    "kubik": "^0.24.0",
    "mime": "^4.1.0",
    "temporal-polyfill": "^0.3.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
